<section id="hero">

    <h1>NICEIC Approved Electrician in <%= Town %></h1>
    
    <p>Fully qualified & insured electrician providing fast, reliable electrical services for homes and businesses.</p>
    
    <p>24/7 Emergency Service</p>

    <a href="tel:<%= phoneNumber %>" class="btn-primary">Call Now <%= phoneNumber %></a>

    <div class="flex trust-badges">
        <img src="<%= imgDir %>/niceic-registered.png"/>

        <img src="<%= imgDir %>/twentyfourseven.png"/>
        
        <img src="<%= imgDir %>/fully-insured.png" />

    </div>


</section>

<section id="home-services">
    
    <h1>Services</h1>

    <div class="services">
    <% for(service of services) { 
            if(service.featured) {
    %>
        <div class="service">
            <img src="<%= service.icon %>"/>
            <h2><%= service.title %></h2>
            <p><%= service.description %></p>
        </div>  

    <% } } %>
    
    </div> 
    
    <a href="/services">View All Services</a>
            


</section> 

<section id="home-emergency">

    <h1>Electrical Emergency?</h1>
    
    <h2>Call Our 24 Electrician Now</h2>

    <a href="tel:<%= phoneNumber %>">Call Now <%= phoneNumber %></a>
    
</section>

<section id="home-why-choose-us"></section>