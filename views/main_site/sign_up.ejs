<%- getTemplatePart('main_site/header_secondary') %>

    <script src="https://unpkg.com/alpinejs@3.x.x/dist/cdn.min.js" defer></script>
    <div class="sign-up-hero">
        <h1>Join Thousands of Trade Businesses<br>Growing with Tradeely</h1>
        <p>Free for 7 days then billed annually or monthly</p>
    </div>
    <section x-data="signupForm()" class="sign-up container">



        <h2>Select Package</h2>

        <h3>Save almost 25% with Annual Billing</h3>

        <div class="flex justify-center interval">
            <input x-model="form.billing" type="radio" id="monthly" value="monthly" name="billing">
            <label for="monthly">Monthly</label>

            <input x-model="form.billing" type="radio" id="annually" value="annual" name="billing">
            <label for="annually">Annually</label>
        </div>

        <div class="pricing-grid">

            <div @click="selectPackage('basic')" class="pricing-card">
                <h4 x-show="form.package === 'basic'" class="selected-badge">Selected</h4>
                <h3>Basic</h3>
                <p>£<span x-text="amount('basic')"></span>/mo</p>

                <button x-show="form.package === 'professional'" class="btn-primary">Select</button>
            </div>

            <div @click="selectPackage('professional')" class=" pricing-card highlight">
                <h4 x-show="form.package === 'professional'" class="selected-badge">Selected</h4>
                <h3>Professional</h3>
                <p>£<span x-text="amount('professional')"></span>/mo</p>
                <button x-show="form.package === 'basic'" class="btn-primary">Select</button>
            </div>
        </div>

        <h2>Create Account</h2>

        <div class="card">

            <!-- Progress Bar -->
            <div class="progress">
                <template x-for="i in 5">
                    <div :class="step >= i ? 'active' : ''"></div>
                </template>
            </div>

            <!-- Step 1 -->
            <div x-show="step === 1">
                <input type="email" placeholder="Email" x-model="form.email">
                <p class="error" x-show="error.displayEmail" x-text="errors.email"></p>
                <input type="password" placeholder="Password" x-model="form.password">
                <p class="error" x-show="error.displayPassword" x-text="errors.password"></p>
                <button class="btn" @click="next()">Next</button>
            </div>

            <!-- Step 2 -->
            <div x-show="step === 2">
                <h3>Select Business Type</h3>

                <input class="search" placeholder="Search..." />

                <div class="flex flex-wrap trade-types justify-center" x-show="businessTypeState == 'types'">
                    <template x-for="type in tradeTypes" :key="type">
                        <div class="trade-option" @click="
                    currentTradeType = type;
                    businessTypeState = 'trades';
                " x-text="type">
                        </div>
                    </template>
                </div>
                <div x-show="businessTypeState === 'trades'">

                    <button class="btn-small" @click="businessTypeState = 'types'">
                        ← Back
                    </button>
                    <div class="flex justify-center flex-wrap">
                    <template x-for="trade in trades[currentTradeType]" :key="trade">
                        <div class="trade-option" @click="
                    form.businessType = trade;
                    loadServices();
                    next();
                " x-text="trade">
                        </div>
                    </template>
                    </div>

                </div>

                <div class="flex justify-between">
                    <button class="btn" @click="prev()">Back</button>
                    <button class="btn" @click="next()">Next</button>
                </div>
            </div>

            <!-- Step 3 -->
            <div x-show="step === 3">
                <h3>Business Name</h3>
                <input type="text" placeholder="Business Name" x-model="form.businessName">
                <div class="flex justify-between">
                    <button class="btn" @click="prev()">Back</button>
                    <button class="btn" @click="next()">Next</button>
                </div>
                
            </div>

            <!-- Step 4 -->
            <div x-show="step === 4">
                <h3>Business Details</h3>
                <input type="text" placeholder="Location (Town/City)" x-model="form.location">
                <input type="number" placeholder="Years in business" x-model="form.years">
                <input type="text" placeholder="Phone Number" x-model="form.phone">
                 <div class="flex justify-between">
                    <button class="btn" @click="prev()">Back</button>
                    <button class="btn" @click="next()">Next</button>
                </div>
            </div>

            <!-- Step 5 -->
            <div x-show="step === 5">

                <h3>About your business</h3>
                <p>Please write a brief description and history of your business for the About Us page.</p>

                <textarea class="trade-description" x-model="form.description"></textarea>
                

                <div class="flex justify-between">
                    <button class="btn" @click="prev()">Back</button>
                    <button class="btn" @click="submit()">Create Account</button>
                </div>
            </div>

        </div>




    </section>

    <script>
        function signupForm() {
            return {
                step: 1,

                packages: {
                    basic: {
                        annual: 19,
                        monthly: 25
                    },
                    professional: {
                        annual: 49,
                        monthly: 65
                    }
                },

                form: {
                    email: '',
                    password: '',
                    businessType: '',
                    businessName: '',
                    location: '',
                    years: '',
                    phone: '',
                    description: '',
                    billing: 'annual',
                    package: 'professional'
                },

                businessTypeState: 'types',
                currentTradeType: '',

                services: [],
                selectedServices: [],
                customService: '',
                searchResults: [],

                serviceTemplates: {
                    Plumber: ['Emergency Repairs', 'Boiler Install', 'Bathroom Install'],
                    Electrician: ['Rewiring', 'Consumer Units', 'EV Chargers'],
                    Builder: ['Extensions', 'Renovations', 'Loft Conversions'],
                    Joiner: ['Custom Cabinets', 'Doors', 'Staircases'],
                    Roofer: ['Roof Repairs', 'Flat Roofing', 'Guttering'],
                    Landscaper: ['Patios', 'Driveways', 'Garden Design'],
                    Other: []
                },

                amount(plan) {
                    return this.packages[plan][this.form.billing];
                },

                selectPackage(package) {
                    this.form.package = package;
                },

                next() {
                    if (this.step < 5) this.step++;
                },

                prev() {
                    if (this.step > 1) this.step--;
                },

                loadServices() {
                    this.services = this.serviceTemplates[this.form.businessType] || [];
                    this.selectedServices = [];
                },

                toggleService(service) {
                    if (this.selectedServices.includes(service)) {
                        this.selectedServices = this.selectedServices.filter(s => s !== service);
                    } else {
                        this.selectedServices.push(service);
                    }
                },

                addService() {
                    if (this.customService.trim() !== '') {
                        this.services.push(this.customService);
                        this.selectedServices.push(this.customService);
                        this.customService = '';
                    }
                },

                submit() {
                    const payload = {
                        ...this.form,
                        services: this.selectedServices
                    };

                    console.log("Submitting:", payload);

                    fetch('/api/signup', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify(payload)
                    });
                }

                ,
                tradeTypes: [
                    "Construction & Building Trades",
                    "Plumbing & Heating",
                    "Electrical",
                    "Carpentry & Joinery",
                    "Roofing & Exteriors",
                    "Finishing Trades",
                    "Landscaping & Outdoor",
                    "HVAC & Specialist Systems",
                    "Windows, Doors & Glazing",
                    "Cleaning & Maintenance Trades",
                    "Specialist & Compliance",
