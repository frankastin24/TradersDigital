

<%- getTemplatePart('main_site/header-secondary', viewContext) %>

<section id="create-website-loader" class="website-loader flex flex-col items-center justify-center">
    <canvas id="tradeelyLoader" width="220" height="220"></canvas>
    <h1>Creating your website</h1>
    <div class="subtitle" id="statusText">Setting up your pages...</div>
</section>


  <script>
    const canvas = document.getElementById("tradeelyLoader");
    const ctx = canvas.getContext("2d");

    const statusText = document.getElementById("statusText");

    const cx = canvas.width / 2;
    const cy = canvas.height / 2;
    const radius = 72;

    let hue = 180;
    let rotation = -Math.PI / 2;
    let progress = 0;

    const statuses = [
      "Setting up your pages...",
      "Adding your services...",
      "Creating your contact form...",
      "Optimising for mobile...",
      "Finalising your website..."
    ];

    function drawBackgroundRing() {
      ctx.beginPath();
      ctx.arc(cx, cy, radius, 0, Math.PI * 2);
      ctx.strokeStyle = "rgba(255,255,255,0.08)";
      ctx.lineWidth = 10;
      ctx.stroke();
    }

    function drawProgressRing() {
      const endAngle = rotation + (Math.PI * 2 * (progress / 100));

      const gradient = ctx.createLinearGradient(0, 0, canvas.width, canvas.height);
      gradient.addColorStop(0, `hsl(${hue}, 90%, 60%)`);
      gradient.addColorStop(0.5, `hsl(${(hue + 40) % 360}, 90%, 62%)`);
      gradient.addColorStop(1, `hsl(${(hue + 80) % 360}, 90%, 64%)`);

      ctx.save();
      ctx.beginPath();
      ctx.arc(cx, cy, radius, rotation, endAngle);
      ctx.strokeStyle = gradient;
      ctx.lineWidth = 10;
      ctx.lineCap = "round";
      ctx.shadowBlur = 20;
      ctx.shadowColor = `hsl(${hue}, 90%, 60%)`;
      ctx.stroke();
      ctx.restore();
    }

    function drawCenterText() {
      ctx.textAlign = "center";
      ctx.textBaseline = "middle";

      ctx.fillStyle = "white";
      ctx.font = "700 34px Arial";
      ctx.fillText(`${Math.floor(progress)}%`, cx, cy - 6);

      ctx.fillStyle = "rgba(255,255,255,0.55)";
      ctx.font = "14px Arial";
      ctx.fillText("Building site", cx, cy + 24);
    }

    function drawDots() {
      const dotCount = 5;
      const spacing = 20;
      const startX = cx - ((dotCount - 1) * spacing) / 2;
      const activeDots = Math.floor((progress / 100) * dotCount);

      for (let i = 0; i < dotCount; i++) {
        ctx.beginPath();
        ctx.arc(startX + i * spacing, cy + 54, 4, 0, Math.PI * 2);

        if (i < activeDots) {
          ctx.fillStyle = `hsl(${(hue + i * 15) % 360}, 90%, 65%)`;
          ctx.shadowBlur = 10;
          ctx.shadowColor = `hsl(${(hue + i * 15) % 360}, 90%, 65%)`;
        } else {
          ctx.fillStyle = "rgba(255,255,255,0.18)";
          ctx.shadowBlur = 0;
        }

        ctx.fill();
      }

      ctx.shadowBlur = 0;
    }

    function updateStatus() {
      if (progress < 20) {
        statusText.textContent = statuses[0];
      } else if (progress < 40) {
        statusText.textContent = statuses[1];
      } else if (progress < 60) {
        statusText.textContent = statuses[2];
      } else if (progress < 80) {
        statusText.textContent = statuses[3];
      } else {
        statusText.textContent = statuses[4];
      }
    }

    function animate() {
      ctx.clearRect(0, 0, canvas.width, canvas.height);

      drawBackgroundRing();
      drawProgressRing();
      drawCenterText();
      drawDots();

      hue = (hue + 0.8) % 360;
      progress += 0.25;

      if (progress > 100) {
        progress = 100;
      }

      updateStatus();

      if (progress < 100) {
        requestAnimationFrame(animate);
      } else {
        statusText.textContent = "Your website is ready";
      }
    }

    animate();
  </script>